# Default: normalize line endings to LF on commit
* text=auto eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Config/data files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.env text eol=lf
*.example text eol=lf

# Binaries
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
